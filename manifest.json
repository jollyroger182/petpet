{
  "display_information": {
    "name": "petpet (dev)"
  },
  "features": {
    "bot_user": {
      "display_name": "petpet (dev)",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/dev-petpet",
        "description": "Create a petpet for a user and adds it as an emoji",
        "usage_hint": "<@user> <emoji-name>",
        "should_escape": true
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["commands", "files:write", "users:read"]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
